{
  "hostname": {
    "transient": "%%NODENAME%%",
    "static": "%%NODENAME%%"
  },
  "root": {
    "password": "%%ROOTPASSWORD%%",
    "hashedPassword": true
  },
  "software": {
    "patterns": [
      "selinux"
    ],
    "packages": []
  },
  "product": {
    "id": "openSUSE_Leap"
  },
  "storage": {
    "drives": [
      {
        "search": "%%INSTALLDISK%%",
        "partitions": [
          {
            "search": "*",
            "delete": true
          },
          {
            "generate": "default"
          }
        ]
      }
    ]
  },
  "localization": {
    "language": "%%LOCALE%%",
    "keyboard": "%%KEYMAP%%",
    "timezone": "%%TIMEZONE%%"
  },
  "scripts": {
    "post": [
      {
        "name": "confluent-prechroot.sh",
        "url": "https://%%DEPLOYER%%/confluent-public/os/%%PROFILE%%/scripts/prechroot.sh",
        "chroot": false
      },
      {
        "name": "confluent-post.sh",
        "url": "https://%%DEPLOYER%%/confluent-public/os/%%PROFILE%%/scripts/post.sh",
        "chroot": true
      }
    ]
  }
}

